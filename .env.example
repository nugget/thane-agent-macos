# Copy to .env and fill in your values.
# .env is gitignored — never commit it.

# Host to deploy the app to (rsync target)
DEPLOY_HOST=your-mac.local

# Path on the deploy host where the .app lands (default: Applications)
# DEPLOY_PATH=Applications

# --- Release engineering ---
# Variable names are aligned with the thane-ai-agent release scripts so a
# single .env file can serve both projects.

# Keychain credential profile for `xcrun notarytool submit`. Set up once via:
#   xcrun notarytool store-credentials thane-notary \
#     --apple-id <you@example.com> --team-id <TEAMID> --password <app-specific-password>
THANE_NOTARY_PROFILE=thane-notary

# Developer ID Application identity used to sign the .app and the DMG.
# Find yours with: security find-identity -v -p codesigning
THANE_CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID1234)

# Override if Xcode.app is not in the standard location
# DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
