# Copy to .env and fill in your values.
# .env is gitignored — never commit it.

# Host to deploy the app to (rsync target)
DEPLOY_HOST=your-mac.local

# Path on the deploy host where the .app lands (default: /Applications)
# DEPLOY_PATH=/Applications

# Keychain credential profile for xcrun notarytool submit
NOTARYTOOL_PROFILE=notarytool

# Override if Xcode.app is not in the standard location
# DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
